    {
      "name": "Add Medicine",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"tradeName\": \"Test Medicine\",\n    \"genericName\": \"Test Generic\",\n    \"unitSellingPrice\": 15.00,\n    \"unitPurchasePrice\": 12.00,\n    \"initialQuantity\": 100,\n    \"reorderThreshold\": 10,\n    \"expiryDate\": \"2025-12-31\",\n    \"vendorId\": 1\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/medicines",
          "host": ["{{base_url}}"],
          "path": ["api", "medicines"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200 or 201\", function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
