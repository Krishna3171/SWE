    {
      "name": "Make Sale",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"items\": [\n        {\n            \"medicineCode\": \"MED1\",\n            \"quantity\": 2\n        }\n    ]\n}"
        },
        "url": {
